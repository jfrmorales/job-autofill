{
  "manifest_version": 3,
  "name": "job-autofill",
  "version": "0.1.0",
  "description": "Rellena candidaturas de empleo con IA (Gemini 3.5 Flash). Tú revisas y envías.",
  "permissions": ["storage", "activeTab", "scripting", "downloads", "webNavigation"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "job-autofill"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": { "id": "job-autofill@jfrmorales", "strict_min_version": "115.0" }
  }
}
