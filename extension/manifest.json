{
  "manifest_version": 3,
  "name": "job-autofill",
  "version": "0.1.0",
  "description": "Fill job applications with AI (Google, OpenAI, Anthropic or any compatible API). You review and submit. · Rellena candidaturas de empleo con IA; tú revisas y envías.",
  "permissions": ["storage", "activeTab", "scripting", "downloads", "webNavigation"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "job-autofill"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["i18n.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": { "id": "job-autofill@jfrmorales", "strict_min_version": "116.0" }
  }
}
